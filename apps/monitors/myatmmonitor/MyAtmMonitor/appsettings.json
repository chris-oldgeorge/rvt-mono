{
  "Infrastructure": "local",
  "MonitorApi": {
    "Enabled": false
  },
  "MyAtmMonitor": {
    "CustomerId": 9,
    "DevicePageSize": 100,
    "MaxDevicePagesPerRun": 100,
    "MeasurementPageSize": 1000,
    "AccessoryPageSize": 1000,
    "MaxPagesPerMonitorPerRun": 10,
    "OutboxBatchSize": 50,
    "OutboxDeliveryTimeoutSeconds": 90,
    "OutboxLeaseSeconds": 120,
    "OutboxRetrySeconds": 30,
    "OutboxMaxAttempts": 8,
    "PortalBaseUrl": "https://www.rvtcloud.com/"
  },
  "MyAtmVendor": {
    "MaxResponseBytes": 4194304,
    "MaximumAttempts": 5,
    "MinimumRequestIntervalMilliseconds": 500,
    "FallbackRetryCapSeconds": 30,
    "MaximumRetryDelaySeconds": 30
  },
  "MonitorScheduler": {
    "Enabled": false,
    "TimeZoneId": "UTC",
    "Jobs": [
      {
        "Name": "StoreMonitors",
        "Cron": "0 2 * * * ?",
        "Enabled": true,
        "Description": "Fetch monitor list hourly at :02."
      },
      {
        "Name": "CheckForOfflineMonitors",
        "Cron": "0 5,25,45 * * * ?",
        "Enabled": true,
        "Description": "Check offline monitor state three times per hour."
      },
      {
        "Name": "StoreDustLevels",
        "Cron": "0 0/30 * * * ?",
        "Enabled": true,
        "Description": "Store all missing one-minute dust samples every 30 minutes."
      },
      {
        "Name": "Store15MinAverageDustLevels",
        "Cron": "0 14,29,44,59 * * * ?",
        "Enabled": true,
        "Description": "Store 15-minute average dust levels."
      },
      {
        "Name": "Store1HourAverageDustLevels",
        "Cron": "0 59 * * * ?",
        "Enabled": true,
        "Description": "Store hourly average dust levels."
      },
      {
        "Name": "Store24HourAverageDustLevels",
        "Cron": "0 59 23 * * ?",
        "Enabled": true,
        "Description": "Store daily average dust levels."
      },
      {
        "Name": "Process8HourAverageDustLevels",
        "Cron": "0 1 * * * ?",
        "Enabled": true,
        "Description": "Process 8-hour average dust levels."
      },
      {
        "Name": "ClearOlderErrorMessages",
        "Cron": "0 0 3 * * ?",
        "Enabled": true,
        "Description": "Clean old error messages daily."
      },
      {
        "Name": "StoreAccessoryInfo",
        "Cron": "0 10 3 * * ?",
        "Enabled": true,
        "Description": "Store accessory information daily."
      },
      {
        "Name": "DispatchOutbox",
        "Cron": "0 * * * * ?",
        "Enabled": true,
        "Description": "Deliver durable notification outbox messages every minute."
      }
    ]
  }
}
