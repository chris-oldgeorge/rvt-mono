*.class

# Compiled Python bytecode
*.py[cod]

# Log files
*.log

# Package files
*.jar

# Maven
target/


# JetBrains IDE
.idea/

# VS Code IDE
.vscode/

# Unit test reports
TEST*.xml
coverage/
playwright-report/
test-results/
