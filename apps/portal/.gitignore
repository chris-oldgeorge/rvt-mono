**/playwright-report/
**/test-results/

# Generated by MacOS
.DS_Store
._*
**/._*
~$*
**/~$*

# Generated by Windows
Thumbs.db

# Applications
*.app
*.exe
*.war

# Large media files
*.mp4
*.tiff
*.avi
*.flv
*.mov
*.wmv

